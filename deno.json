{
  "name": "take-a-note",
  "version": "0.1.1",
  "description": "A zero-login, frictionless note-taking web application. Features offline-first storage (IndexedDB) and secure, serverless device-to-device syncing.",
  "license": "AGPL-3.0-or-later",

  "exports": "./README.md",

  "tasks": {
    "dev": "vite",
    "build": "vite build",
    "check": "deno check src"
  },

  "nodeModulesDir": "auto",
  "imports": {
    "#app/": "./src/app/",
    "#pages/": "./src/pages/",
    "#entities/": "./src/entities/",
    "#shared/": "./src/shared/",

    "@deno/vite-plugin": "npm:@deno/vite-plugin@^2.0.2",
    "@praha/byethrow": "npm:@praha/byethrow@^0.11.1",
    "@std/uuid": "jsr:@std/uuid@^1.1.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.3",
    "@tanstack/router-plugin": "npm:@tanstack/router-plugin@^1.167.22",
    "@tanstack/solid-router": "npm:@tanstack/solid-router@^1.168.20",
    "@valibot/valibot": "jsr:@valibot/valibot@^1.3.1",
    "idb": "npm:idb@^8.0.3",
    "solid-js": "npm:solid-js@^1.9.12",
    "tailwindcss": "npm:tailwindcss@^4.2.3",
    "vite": "npm:vite@^8.0.3",
    "vite-plugin-icons-spritesheet": "npm:vite-plugin-icons-spritesheet@^3.0.1",
    "vite-plugin-solid": "npm:vite-plugin-solid@^2.11.11"
  },

  "exclude": ["**/*.gen.ts"],

  "compilerOptions": {
    "module": "esnext",
    "lib": ["esnext", "dom", "dom.iterable", "deno.ns"],
    "types": ["vite/client"],

    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  }
}
